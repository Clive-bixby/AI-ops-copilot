    {
      "name": "04 - Upload Document (.txt or .pdf)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "x-organization-id",
            "value": "{{organizationId}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/documents/upload",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "documents",
            "upload"
          ]
        },
        "description": "In Postman Body tab, select a local .txt or .pdf file for key `file`."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Response has id, filename, processing', function () {",
              "  pm.expect(body.id).to.be.a('string').and.not.empty;",
              "  pm.expect(body.filename).to.be.a('string').and.not.empty;",
              "  pm.expect(body.processing).to.be.an('object');",
              "  pm.expect(body.processing.status).to.be.a('string');",
              "});",
              "",
              "pm.environment.set('documentId', body.id);",
              "",
              "pm.test('processing.status is processed or failed', function () {",
              "  pm.expect(['processed', 'failed']).to.include(body.processing.status);",
              "});",
              "",
              "if (body.processing.status === 'failed') {",
              "  console.warn('Document processing failed:', body.processing.error);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - List Documents",
      "request": {
        "method": "GET",
