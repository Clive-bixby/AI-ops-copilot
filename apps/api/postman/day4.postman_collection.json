    {
      "name": "02 - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"organizationName\": \"{{organizationName}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Token exists in response', function () {",
              "  pm.expect(body.token).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.environment.set('token', body.token);",
              "",
              "function decodeJwtPayload(token) {",
              "  const parts = token.split('.');",
              "  if (parts.length !== 3) return null;",
              "  const base64Url = parts[1];",
              "  const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');",
              "  const padded = base64 + '='.repeat((4 - (base64.length % 4)) % 4);",
              "  try {",
              "    return JSON.parse(atob(padded));",
              "  } catch (error) {",
              "    console.log('JWT decode error:', error);",
              "    return null;",
              "  }",
              "}",
              "",
              "const payload = decodeJwtPayload(body.token);",
              "if (payload && payload.organizationId) {",
              "  pm.environment.set('organizationId', payload.organizationId);",
              "}",
              "",
              "pm.test('organizationId extracted from JWT', function () {",
              "  const orgId = pm.environment.get('organizationId');",
              "  pm.expect(orgId).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ]
    },
