        "url": {
          "raw": "{{baseUrl}}/documents",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "documents"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const docs = pm.response.json();",
              "pm.test('Response is an array', function () {",
              "  pm.expect(docs).to.be.an('array');",
              "});",
              "",
              "const documentId = pm.environment.get('documentId');",
              "if (documentId) {",
              "  const found = docs.find((doc) => doc.id === documentId);",
              "  pm.test('Uploaded document is listed', function () {",
              "    pm.expect(found, 'Document not found in list').to.exist;",
              "  });",
              "",
              "  if (found) {",
              "    pm.test('Document has processingStatus field', function () {",
              "      pm.expect(found).to.have.property('processingStatus');",
              "    });",
              "  }",
              "}"
            ]
          }
        }
      ]
